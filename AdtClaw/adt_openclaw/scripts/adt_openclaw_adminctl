#!/usr/bin/env bash
set -euo pipefail

sub="${1:-}"
shift || true

die() {
  echo "ERROR: $*" >&2
  exit 1
}

case "$sub" in
  restart-odoo)
    service="${1:-}"
    [[ -n "$service" ]] || die "service required"
    systemctl restart "$service"
    systemctl is-active "$service"
    ;;
  git-pull)
    repo_path="${1:-}"
    [[ -n "$repo_path" ]] || die "repo path required"
    [[ -d "$repo_path/.git" ]] || die "not a git repo"
    git -C "$repo_path" pull --ff-only
    ;;
  status)
    uname -a
    echo "---"
    uptime
    echo "---"
    df -h /
    ;;
  tail-log)
    log_path="${1:-}"
    lines="${2:-100}"
    [[ -f "$log_path" ]] || die "log path not found"
    [[ "$lines" =~ ^[0-9]+$ ]] || die "lines must be number"
    tail -n "$lines" "$log_path"
    ;;
  *)
    die "unsupported subcommand"
    ;;
esac

