<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_openclaw_instance_tree" model="ir.ui.view">
        <field name="name">openclaw.instance.tree</field>
        <field name="model">openclaw.instance</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="base_url"/>
                <field name="is_active"/>
                <field name="health_status"/>
                <field name="last_seen"/>
            </list>
        </field>
    </record>

    <record id="view_openclaw_instance_form" model="ir.ui.view">
        <field name="name">openclaw.instance.form</field>
        <field name="model">openclaw.instance</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="base_url"/>
                        <field name="is_active"/>
                        <field name="shared_secret" password="True"/>
                    </group>
                    <group>
                        <field name="health_status"/>
                        <field name="last_seen"/>
                        <field name="timeout_seconds"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_openclaw_session_tree" model="ir.ui.view">
        <field name="name">openclaw.session.tree</field>
        <field name="model">openclaw.session</field>
        <field name="arch" type="xml">
            <list>
                <field name="channel"/>
                <field name="chat_user_id"/>
                <field name="odoo_db"/>
                <field name="odoo_login"/>
                <field name="state"/>
                <field name="last_seen"/>
                <field name="expires_at"/>
            </list>
        </field>
    </record>

    <record id="view_openclaw_session_form" model="ir.ui.view">
        <field name="name">openclaw.session.form</field>
        <field name="model">openclaw.session</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="channel"/>
                        <field name="chat_user_id"/>
                        <field name="odoo_base_url"/>
                        <field name="odoo_db"/>
                        <field name="odoo_uid"/>
                        <field name="odoo_login"/>
                        <field name="company_id"/>
                        <field name="allowed_company_ids" widget="many2many_tags"/>
                        <field name="state"/>
                        <field name="last_seen"/>
                        <field name="expires_at"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_openclaw_admin_session_tree" model="ir.ui.view">
        <field name="name">openclaw.admin.session.tree</field>
        <field name="model">openclaw.admin_session</field>
        <field name="arch" type="xml">
            <list>
                <field name="channel"/>
                <field name="chat_user_id"/>
                <field name="verified"/>
                <field name="verified_at"/>
                <field name="expires_at"/>
                <field name="audit_count"/>
            </list>
        </field>
    </record>

    <record id="view_openclaw_audit_tree" model="ir.ui.view">
        <field name="name">openclaw.audit.tree</field>
        <field name="model">openclaw.audit</field>
        <field name="arch" type="xml">
            <list>
                <field name="created_at"/>
                <field name="event_type"/>
                <field name="session_id"/>
                <field name="admin_session_id"/>
                <field name="model"/>
                <field name="method"/>
                <field name="os_command_key"/>
            </list>
        </field>
    </record>

    <record id="view_openclaw_audit_form" model="ir.ui.view">
        <field name="name">openclaw.audit.form</field>
        <field name="model">openclaw.audit</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="created_at"/>
                        <field name="event_type"/>
                        <field name="session_id"/>
                        <field name="admin_session_id"/>
                        <field name="model"/>
                        <field name="method"/>
                        <field name="res_ids"/>
                        <field name="os_command_key"/>
                    </group>
                    <group>
                        <field name="request_json" widget="text"/>
                        <field name="response_json" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_openclaw_instance" model="ir.actions.act_window">
        <field name="name">Instances</field>
        <field name="res_model">openclaw.instance</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_openclaw_session" model="ir.actions.act_window">
        <field name="name">Sessions</field>
        <field name="res_model">openclaw.session</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_openclaw_admin_session" model="ir.actions.act_window">
        <field name="name">Admin Sessions</field>
        <field name="res_model">openclaw.admin_session</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_openclaw_audit" model="ir.actions.act_window">
        <field name="name">Audit Logs</field>
        <field name="res_model">openclaw.audit</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

