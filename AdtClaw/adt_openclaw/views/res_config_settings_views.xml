<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_openclaw" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.adt.openclaw</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="OpenClaw" name="adt_openclaw_app">
                    <block title="AI Agent Identity">
                        <setting string="Enable AI Agent">
                            <field name="openclaw_ai_agent_enabled"/>
                        </setting>
                        <setting string="AI Agent Login">
                            <field name="openclaw_ai_agent_login"/>
                        </setting>
                        <setting string="AI Agent Display Name">
                            <field name="openclaw_ai_agent_name"/>
                        </setting>
                        <setting string="AI Agent Password">
                            <field name="openclaw_ai_agent_password" password="True"/>
                        </setting>
                        <setting string="AI Agent Company Scope">
                            <field name="openclaw_ai_agent_company_scope"/>
                        </setting>
                        <div class="text-muted">
                            Recommended login: <code>iadmin</code>. Disable this setting to turn off assistant execution without deleting the account.
                            Grant only business-module groups here; keep system configuration and admin groups separate.
                        </div>
                    </block>
                    <block title="Messenger">
                        <setting string="LINE Channel Secret">
                            <field name="openclaw_line_channel_secret" password="True"/>
                        </setting>
                        <setting string="LINE Access Token">
                            <field name="openclaw_line_access_token" password="True"/>
                        </setting>
                    </block>
                    <block title="Integration">
                        <setting string="Public Base URL">
                            <field name="openclaw_public_base_url"/>
                        </setting>
                        <setting string="OpenClaw Base URL">
                            <field name="openclaw_instance_base_url"/>
                        </setting>
                        <setting string="OpenClaw Shared Secret">
                            <field name="openclaw_instance_shared_secret" password="True"/>
                        </setting>
                    </block>
                    <block title="Admin OS Scope">
                        <setting string="Admin Login Allowlist (CSV)">
                            <field name="openclaw_admin_logins"/>
                        </setting>
                        <setting string="Admin Verify Code">
                            <field name="openclaw_admin_verify_code" password="True"/>
                        </setting>
                        <setting string="adminctl Path">
                            <field name="openclaw_adminctl_path"/>
                        </setting>
                        <setting string="Service Allowlist (CSV)">
                            <field name="openclaw_service_allowlist"/>
                        </setting>
                        <setting string="Repo Allowlist (CSV key=path)">
                            <field name="openclaw_repo_allowlist"/>
                        </setting>
                        <setting string="Log Allowlist (CSV key=path)">
                            <field name="openclaw_log_allowlist"/>
                        </setting>
                    </block>
                    <block title="Odoo Scope">
                        <setting string="Business Model Allowlist (optional)">
                            <field name="openclaw_allowed_models"/>
                        </setting>
                        <div class="text-muted">
                            Leave this blank to allow all non-system business models. System configuration models are always blocked.
                        </div>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
