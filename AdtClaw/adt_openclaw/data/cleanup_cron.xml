<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_openclaw_expire_sessions" model="ir.cron">
        <field name="name">OpenClaw Expire Sessions</field>
        <field name="model_id" ref="model_openclaw_session"/>
        <field name="state">code</field>
        <field name="code">model.cron_expire_sessions()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_openclaw_expire_admin_sessions" model="ir.cron">
        <field name="name">OpenClaw Expire Admin Sessions</field>
        <field name="model_id" ref="model_openclaw_admin_session"/>
        <field name="state">code</field>
        <field name="code">model.cron_expire_admin()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_openclaw_expire_tokens" model="ir.cron">
        <field name="name">OpenClaw Expire Share Tokens</field>
        <field name="model_id" ref="model_openclaw_share_token"/>
        <field name="state">code</field>
        <field name="code">model.cron_expire_tokens()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>
</odoo>

