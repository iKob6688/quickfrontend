<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_openclaw_partner_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>OpenClaw Partner Report</h2>
                        <p><strong>Name:</strong> <span t-esc="o.name"/></p>
                        <p><strong>Email:</strong> <span t-esc="o.email or '-'"/></p>
                        <p><strong>Phone:</strong> <span t-esc="o.phone or '-'"/></p>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_openclaw_partner" model="ir.actions.report">
        <field name="name">OpenClaw Partner Report</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">adt_openclaw.report_openclaw_partner_document</field>
        <field name="report_file">adt_openclaw.report_openclaw_partner_document</field>
        <field name="print_report_name">'OpenClaw Partner - %s' % (object.name)</field>
    </record>
</odoo>

