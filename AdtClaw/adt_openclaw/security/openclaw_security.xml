<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_openclaw" model="ir.module.category">
        <field name="name">OpenClaw</field>
        <field name="description">OpenClaw messenger access</field>
        <field name="sequence">29</field>
    </record>

    <record id="group_openclaw_user" model="res.groups">
        <field name="name">OpenClaw User</field>
        <field name="category_id" ref="adt_openclaw.module_category_openclaw"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_openclaw_admin" model="res.groups">
        <field name="name">OpenClaw Admin</field>
        <field name="category_id" ref="adt_openclaw.module_category_openclaw"/>
        <field name="implied_ids" eval="[(4, ref('adt_openclaw.group_openclaw_user'))]"/>
    </record>

    <record id="group_openclaw_auditor" model="res.groups">
        <field name="name">OpenClaw Auditor</field>
        <field name="category_id" ref="adt_openclaw.module_category_openclaw"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="openclaw_session_own_rule" model="ir.rule">
        <field name="name">OpenClaw Session Own</field>
        <field name="model_id" ref="model_openclaw_session"/>
        <field name="groups" eval="[(4, ref('adt_openclaw.group_openclaw_user'))]"/>
        <field name="domain_force">[('odoo_uid', '=', user.id)]</field>
    </record>

    <record id="openclaw_share_token_own_rule" model="ir.rule">
        <field name="name">OpenClaw Share Token Own</field>
        <field name="model_id" ref="model_openclaw_share_token"/>
        <field name="groups" eval="[(4, ref('adt_openclaw.group_openclaw_user'))]"/>
        <field name="domain_force">[('uid', '=', user.id)]</field>
    </record>
</odoo>

